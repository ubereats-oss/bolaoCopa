126:   Future<void> _salvar({
127:     String? id,
128:     required String text,
129:     required ExtraQuestionType type,
130:     required int order,
131:   }) async {
132:     if (_cupId == null) return;
133:     final ref = _db
134:         .collection('cups')
135:         .doc(_cupId)
136:         .collection('extra_questions');
137:     final data = {
138:       'question': text,
139:       'type': type == ExtraQuestionType.team ? 'team' : 'player',
140:       'order': order,
141:     };
142:     if (id == null) {
143:       await ref.add(data);
144:     } else {
145:       await ref.doc(id).update(data);
146:     }
147:     await _carregar();
