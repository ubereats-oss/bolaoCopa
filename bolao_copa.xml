 23:   // Registro com e-mail e senha
 24:   Future<UserCredential> registerWithEmail({
 25:     required String name,
 26:     required String email,
 27:     required String password,
 28:   }) async {
 29:     final credential = await _auth.createUserWithEmailAndPassword(
 30:       email: email.trim(),
 31:       password: password,
 32:     );
 33:     await credential.user?.updateDisplayName(name);
 34:     await _saveUserToFirestore(
 35:       uid: credential.user!.uid,
 36:       name: name,
 37:       email: email.trim(),
 38:     );
 39:     return credential;
 40:   }
 41: 
 42:   // Login com Google
 43:   Future<UserCredential?> signInWithGoogle() async {
 44:     final googleUser = await _googleSignIn.signIn();
 45:     if (googleUser == null) return null;
 46:     final googleAuth = await googleUser.authentication;
 47:     final credential = GoogleAuthProvider.credential(
 48:       accessToken: googleAuth.accessToken,
 49:       idToken: googleAuth.idToken,
 50:     );
 51:     final userCredential = await _auth.signInWithCredential(credential);
 52:     // Cria o perfil no Firestore apenas se for o primeiro login
 53:     final doc =
 54:         await _db.collection('users').doc(userCredential.user!.uid).get();
 55:     if (!doc.exists) {
 56:       await _saveUserToFirestore(
 57:         uid: userCredential.user!.uid,
 58:         name: googleUser.displayName ?? 'Usuário',
 59:         email: googleUser.email,
 60:       );
 61:     }
 62:     return userCredential;
 63:   }
