 4: 
 5: class MatchRepository {
 6:   final FirebaseFirestore _db = FirebaseFirestore.instance;
 7:   // Cache em memória por copa
 8:   static final Map<String, List<Match>> _groupMatchesCache = {};
 9:   static final Map<String, List<Match>> _knockoutMatchesCache = {};
10:   static final Map<String, Map<String, Team>> _teamsCache = {};
11:   static void clearCache() {
12:     _groupMatchesCache.clear();
13:     _knockoutMatchesCache.clear();
14:     _teamsCache.clear();
15:   }
16: 
17:   Future<List<Match>> fetchGroupMatches(String cupId,
18:       {bool forceRefresh = false}) async {
19:     if (!forceRefresh && _groupMatchesCache.containsKey(cupId)) {
20:       return _groupMatchesCache[cupId]!;
21:     }
22:     final groupsSnapshot =
23:         await _db.collection('cups').doc(cupId).collection('groups').get();
24:     final List<Match> matches = [];
25:     for (final groupDoc in groupsSnapshot.docs) {
26:       final matchesSnapshot = await _db
27:           .collection('cups')
28:           .doc(cupId)
29:           .collection('groups')
30:           .doc(groupDoc.id)
31:           .collection('matches')
32:           .get();
33:       for (final doc in matchesSnapshot.docs) {
34:         final data = doc.data()..['group_id'] = groupDoc.id.toUpperCase();
35:         matches.add(Match.fromFirestore(doc.id, data));
36:       }
37:     }
38:     matches.sort((a, b) => a.matchTime.compareTo(b.matchTime));
39:     _groupMatchesCache[cupId] = matches;
40:     return matches;
41:   }
42: 
43:   Future<List<Match>> fetchKnockoutMatches(String cupId,
44:       {bool forceRefresh = false}) async {
45:     if (!forceRefresh && _knockoutMatchesCache.containsKey(cupId)) {
46:       return _knockoutMatchesCache[cupId]!;
47:     }
48:     final snapshot = await _db
49:         .collection('cups')
50:         .doc(cupId)
51:         .collection('knockout_matches')
52:         .get();
53:     final matches = snapshot.docs
54:         .map((doc) => Match.fromFirestore(doc.id, doc.data()))
55:         .toList();
56:     matches.sort((a, b) => a.matchTime.compareTo(b.matchTime));
57:     _knockoutMatchesCache[cupId] = matches;
58:     return matches;
59:   }
60: 
61:   Future<Match?> fetchMatch(
62:       String cupId, String matchId, String? groupId) async {
63:     DocumentSnapshot doc;
64:     if (groupId != null) {
65:       doc = await _db
66:           .collection('cups')
67:           .doc(cupId)
68:           .collection('groups')
69:           .doc(groupId)
70:           .collection('matches')
71:           .doc(matchId)
72:           .get();
73:     } else {
74:       doc = await _db
75:           .collection('cups')
76:           .doc(cupId)
77:           .collection('knockout_matches')
78:           .doc(matchId)
79:           .get();
80:     }
81:     if (!doc.exists) return null;
82:     return Match.fromFirestore(doc.id, doc.data() as Map<String, dynamic>);
83:   }
84: 
85:   Future<Map<String, Team>> fetchTeams(String cupId,
86:       {bool forceRefresh = false}) async {
87:     if (!forceRefresh && _teamsCache.containsKey(cupId)) {
88:       return _teamsCache[cupId]!;
89:     }
90:     final snapshot =
91:         await _db.collection('cups').doc(cupId).collection('teams').get();
92:     final teams = {
93:       for (final doc in snapshot.docs)
94:         doc.id: Team.fromFirestore(doc.id, doc.data())
95:     };
96:     _teamsCache[cupId] = teams;
97:     return teams;
98:   }
99: }
