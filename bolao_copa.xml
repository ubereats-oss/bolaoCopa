 12: 
 13: class MatchesScreen extends StatefulWidget {
 14:   final String groupId;
 15: 
 16:   const MatchesScreen({super.key, required this.groupId});
 17: 
 18:   @override
 19:   State<MatchesScreen> createState() => _MatchesScreenState();
 20: }
 21: 
 22: class _MatchesScreenState extends State<MatchesScreen>
 23:     with SingleTickerProviderStateMixin {
 24:   final _matchRepo = MatchRepository();
 25:   final _firestoreService = FirestoreService();
 26:   late final GroupRepository _groupRepo;
 27: 
 28:   late TabController _tabController;
 29: 
 30:   List<Match> _groupMatches = [];
 31:   Map<String, Team> _teams = {};
 32:   Cup? _cup;
 33: 
 34:   // null = sem palpite salvo; List<int> = palpite salvo pelo usuário
 35:   final Map<String, List<int>?> _palpites = {};
 36:   final Map<String, bool> _saving = {};
 37:   bool _savingAll = false;
 38:   bool _loading = true;
 39:   String? _erro;
 40: 
 41:   @override
 42:   void initState() {
 43:     super.initState();
 44:     _groupRepo = GroupRepository();
 45:     _tabController = TabController(length: 2, vsync: this);
 46:     _carregar();
 47:   }
 48: 
 49:   @override
 50:   void dispose() {
 51:     _tabController.dispose();
 52:     super.dispose();
 53:   }
 54: 
 55:   Future<void> _carregar() async {
 56:     try {
 57:       final cup = await _firestoreService.fetchActiveCup();
 58:       if (cup == null) {
 59:         setState(() {
 60:           _erro = 'Nenhum bolão ativo encontrado.';
 61:           _loading = false;
 62:         });
 63:         return;
 64:       }
 65:       _cup = cup;
 66:       final uid = FirebaseAuth.instance.currentUser!.uid;
 67: 
 68:       final results = await Future.wait([
 69:         _matchRepo.fetchGroupMatches(cup.id),
 70:         _matchRepo.fetchTeams(cup.id),
 71:         _groupRepo.fetchAllPredictions(widget.groupId, uid),
 72:       ]);
 73: 
 74:       final groupMatches = results[0] as List<Match>;
 75:       final teams = results[1] as Map<String, Team>;
 76:       final predictions = results[2] as Map<String, Prediction>;
 77: 
 78:       // Inicializa todos como null (sem palpite)
 79:       final Map<String, List<int>?> palpites = {
 80:         for (final m in groupMatches) m.id: null,
 81:       };
 82:       // Sobrescreve apenas os que têm palpite salvo
 83:       for (final entry in predictions.entries) {
 84:         palpites[entry.key] = [entry.value.homeGoals, entry.value.awayGoals];
 85:       }
 86: 
 87:       setState(() {
 88:         _groupMatches = groupMatches;
 89:         _teams = teams;
 90:         _palpites.addAll(palpites);
 91:         _loading = false;
 92:       });
 93:     } catch (_) {
 94:       setState(() {
 95:         _erro = 'Erro ao carregar jogos.';
 96:         _loading = false;
 97:       });
 98:     }
 99:   }
100: 
101:   void _incrementar(String matchId, int side) {
102:     if (_cup?.isLocked ?? true) return;
103:     setState(() {
104:       final atual = _palpites[matchId] ?? [0, 0];
105:       final novo = List<int>.from(atual);
106:       novo[side] = (novo[side] + 1).clamp(0, 99);
107:       _palpites[matchId] = novo;
108:     });
109:   }
110: 
111:   void _decrementar(String matchId, int side) {
112:     if (_cup?.isLocked ?? true) return;
113:     setState(() {
114:       final atual = _palpites[matchId] ?? [0, 0];
115:       final novo = List<int>.from(atual);
116:       novo[side] = (novo[side] - 1).clamp(0, 99);
117:       _palpites[matchId] = novo;
118:     });
119:   }
120: 
121:   Future<void> _salvarUm(Match match) async {
122:     final uid = FirebaseAuth.instance.currentUser!.uid;
123:     setState(() => _saving[match.id] = true);
124:     try {
125:       final gols = _palpites[match.id] ?? [0, 0];
126:       await _groupRepo.savePrediction(
127:         widget.groupId,
128:         Prediction(
129:           matchId: match.id,
130:           userId: uid,
131:           homeGoals: gols[0],
132:           awayGoals: gols[1],
133:           savedAt: DateTime.now(),
134:         ),
135:       );
136:       setState(() => _palpites[match.id] = gols);
137:       if (mounted) {
138:         ScaffoldMessenger.of(context).showSnackBar(const SnackBar(
139:           content: Text('Palpite salvo!'),
140:           duration: Duration(seconds: 1),
141:           backgroundColor: Color(0xFF1A6B3C),
142:         ));
143:       }
144:     } catch (_) {
145:       if (mounted) {
146:         ScaffoldMessenger.of(context).showSnackBar(const SnackBar(
147:           content: Text('Erro ao salvar palpite.'),
148:           backgroundColor: Colors.red,
149:         ));
150:       }
151:     } finally {
152:       if (mounted) setState(() => _saving[match.id] = false);
153:     }
154:   }
155: 
156:   Future<void> _salvarTodos() async {
157:     final uid = FirebaseAuth.instance.currentUser!.uid;
158:     setState(() => _savingAll = true);
159:     try {
160:       for (final match in _groupMatches) {
161:         final gols = _palpites[match.id] ?? [0, 0];
162:         await _groupRepo.savePrediction(
163:           widget.groupId,
164:           Prediction(
165:             matchId: match.id,
166:             userId: uid,
167:             homeGoals: gols[0],
168:             awayGoals: gols[1],
169:             savedAt: DateTime.now(),
170:           ),
171:         );
172:         _palpites[match.id] = gols;
173:       }
174:       if (mounted) {
175:         ScaffoldMessenger.of(context).showSnackBar(SnackBar(
176:           content: Text('${_groupMatches.length} palpites salvos!'),
177:           backgroundColor: const Color(0xFF1A6B3C),
178:         ));
179:       }
180:     } catch (_) {
181:       if (mounted) {
182:         ScaffoldMessenger.of(context).showSnackBar(const SnackBar(
183:           content: Text('Erro ao salvar palpites.'),
184:           backgroundColor: Colors.red,
185:         ));
186:       }
187:     } finally {
188:       if (mounted) setState(() => _savingAll = false);
189:     }
190:   }
191: 
192:   @override
193:   Widget build(BuildContext context) {
194:     return Scaffold(
195:       appBar: AppBar(
196:         title: const Text('Meus Palpites'),
197:         backgroundColor: const Color(0xFF1A6B3C),
198:         foregroundColor: Colors.white,
199:         bottom: TabBar(
200:           controller: _tabController,
201:           labelColor: Colors.white,
202:           unselectedLabelColor: Colors.white60,
203:           indicatorColor: Colors.white,
204:           tabs: const [
205:             Tab(text: 'Fase de Grupos'),
206:             Tab(text: 'Mata-Mata'),
207:           ],
208:         ),
209:       ),
210:       body: _loading
211:           ? const Center(child: CircularProgressIndicator())
212:           : _erro != null
213:               ? Center(child: Text(_erro!))
214:               : TabBarView(
215:                   controller: _tabController,
216:                   children: [
217:                     MatchListTab(
218:                       matches: _groupMatches,
219:                       teams: _teams,
220:                       cup: _cup!,
221:                       palpites: _palpites,
222:                       saving: _saving,
223:                       savingAll: _savingAll,
224:                       onIncrement: _incrementar,
225:                       onDecrement: _decrementar,
226:                       onSaveOne: _salvarUm,
227:                       onSaveAll: _salvarTodos,
228:                     ),
229:                     KnockoutBracketScreen(
230:                       cup: _cup!,
231:                       groupMatches: _groupMatches,
232:                       groupPredictions: _palpites,
233:                       teams: _teams,
234:                     ),
235:                   ],
236:                 ),
237:     );
238:   }
239: }
