 31:   bool _locked = false;
 32:   bool _loading = true;
 33:   String? _erro;
 34:   String? _cupId;
 35: 
 36:   @override
 37:   void initState() {
 38:     super.initState();
 39:     _groupRepo = GroupRepository();
 40:     _carregar();
 41:   }
 42: 
 43:   Future<void> _carregar() async {
 44:     try {
 45:       final cup = await _firestoreService.fetchActiveCup();
 46:       if (cup == null) {
 47:         setState(() {
 48:           _erro = 'Nenhum bolão ativo encontrado.';
 49:           _loading = false;
 50:         });
 51:         return;
 52:       }
 53:       _cupId = cup.id;
 54:       _locked = cup.isLocked;
 55:       final uid = FirebaseAuth.instance.currentUser!.uid;
 56: 
 57:       final results = await Future.wait([
 58:         _extraRepo.fetchQuestions(cup.id),
 59:         _groupRepo.fetchAllExtraPredictions(widget.groupId, uid),
 60:         _extraRepo.fetchTeams(cup.id),
 61:         _extraRepo.fetchPlayers(cup.id),
 62:       ]);
 63: 
 64:       setState(() {
 65:         _questions = results[0] as List<ExtraQuestion>;
 66:         _predictions = results[1] as Map<String, ExtraPrediction>;
 67:         _teams = results[2] as List<Team>;
 68:         _players = results[3] as List<Player>;
 69:         _loading = false;
 70:       });
 71:     } catch (_) {
 72:       setState(() {
 73:         _erro = 'Erro ao carregar perguntas.';
 74:         _loading = false;
 75:       });
 76:     }
 77:   }
 78: 
 79:   Future<void> _salvar(String questionId, String answer) async {
 80:     if (_locked || _cupId == null) return;
 81:     final uid = FirebaseAuth.instance.currentUser!.uid;
 82:     final prediction = ExtraPrediction(
 83:       questionId: questionId,
 84:       userId: uid,
 85:       answer: answer,
 86:       savedAt: DateTime.now(),
 87:     );
 88:     await _groupRepo.saveExtraPrediction(widget.groupId, prediction);
 89:     setState(() => _predictions[questionId] = prediction);
 90:   }
 91: 
 92:   Set<String> _teamsJaEscolhidos(String questionIdAtual) {
 93:     final Set<String> usados = {};
 94:     for (final q in _questions) {
 95:       if (q.type == ExtraQuestionType.team && q.id != questionIdAtual) {
 96:         final pred = _predictions[q.id];
 97:         if (pred != null && pred.answer.isNotEmpty) usados.add(pred.answer);
 98:       }
 99:     }
100:     return usados;
101:   }
102: 
103:   @override
104:   Widget build(BuildContext context) {
105:     return Scaffold(
106:       appBar: AppBar(
107:         title: const Text('Palpites Extras'),
108:         backgroundColor: const Color(0xFF1A6B3C),
109:         foregroundColor: Colors.white,
110:       ),
111:       body: _loading
112:           ? const Center(child: CircularProgressIndicator())
113:           : _erro != null
114:               ? Center(child: Text(_erro!))
115:               : _buildBody(),
116:     );
117:   }
118: 
119:   Widget _buildBody() {
120:     if (_questions.isEmpty) {
121:       return const Center(child: Text('Nenhuma pergunta disponível.'));
122:     }
123:     return Column(
124:       children: [
125:         if (_locked)
126:           Container(
127:             width: double.infinity,
128:             color: Colors.orange.withValues(alpha: 0.1),
129:             padding:
130:                 const EdgeInsets.symmetric(vertical: 10, horizontal: 16),
131:             child: const Row(
132:               mainAxisAlignment: MainAxisAlignment.center,
133:               children: [
134:                 Icon(Icons.lock_outline, color: Colors.orange, size: 18),
135:                 SizedBox(width: 8),
136:                 Text('A Copa já começou. Palpites encerrados.',
137:                     style: TextStyle(color: Colors.orange)),
138:               ],
139:             ),
140:           ),
141:         Expanded(
142:           child: ListView.builder(
143:             padding: const EdgeInsets.all(12),
144:             itemCount: _questions.length,
145:             itemBuilder: (context, index) {
146:               final question = _questions[index];
147:               return QuestionCard(
148:                 question: question,
149:                 prediction: _predictions[question.id],
150:                 teams: _teams,
151:                 players: _players,
152:                 locked: _locked,
153:                 teamsExcluidos: question.type == ExtraQuestionType.team
154:                     ? _teamsJaEscolhidos(question.id)
155:                     : {},
156:                 onSave: (answer) => _salvar(question.id, answer),
157:               );
158:             },
159:           ),
160:         ),
161:       ],
162:     );
163:   }
164: }
</file>

