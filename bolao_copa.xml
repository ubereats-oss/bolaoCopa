 23:   void initState() {
 24:     super.initState();
 25:     _carregar();
 26:   }
 27:   Future<void> _carregar({bool forceRefresh = false}) async {
 28:     try {
 29:       final cup = await _firestoreService.fetchActiveCup(
 30:           forceRefresh: forceRefresh);
 31:       if (cup == null) {
 32:         setState(() {
 33:           _erro = 'Nenhum bolão ativo encontrado.';
 34:           _loading = false;
 35:         });
 36:         return;
 37:       }
 38:       _cupId = cup.id;
 39:       final results = await Future.wait([
 40:         _matchRepo.fetchGroupMatches(cup.id, forceRefresh: forceRefresh),
 41:         _matchRepo.fetchKnockoutMatches(cup.id, forceRefresh: forceRefresh),
 42:         _matchRepo.fetchTeams(cup.id, forceRefresh: forceRefresh),
 43:       ]);
 44:       final group = results[0] as List<Match>;
 45:       final knockout = results[1] as List<Match>;
 46:       setState(() {
 47:         _matches = [...group, ...knockout]
 48:           ..sort((a, b) => a.matchTime.compareTo(b.matchTime));
 49:         _teams = results[2] as Map<String, Team>;
 50:         _loading = false;
 51:       });
 52:     } catch (e) {
 53:       setState(() {
 54:         _erro = 'Erro ao carregar jogos.';
 55:         _loading = false;
 56:       });
 57:     }
 58:   }
 59:   Future<void> _abrirEdicao(Match match) async {
 60:     final homeCtrl = TextEditingController(
 61:         text: match.officialHomeGoals?.toString() ?? '');
 62:     final awayCtrl = TextEditingController(
 63:         text: match.officialAwayGoals?.toString() ?? '');
 64:     String? erroDialog;
 65:     await showDialog(
 66:       context: context,
 67:       builder: (context) {
 68:         return StatefulBuilder(
 69:           builder: (context, setDialogState) {
 70:             return AlertDialog(
 71:               title: Text(
 72:                 '${_teams[match.homeTeamId]?.name ?? match.homeTeamId} × '
 73:                 '${_teams[match.awayTeamId]?.name ?? match.awayTeamId}',
 74:               ),
 75:               content: Column(
 76:                 mainAxisSize: MainAxisSize.min,
 77:                 children: [
 78:                   Row(
 79:                     mainAxisAlignment: MainAxisAlignment.center,
 80:                     children: [
 81:                       SizedBox(
 82:                         width: 60,
 83:                         child: TextField(
 84:                           controller: homeCtrl,
 85:                           keyboardType: TextInputType.number,
 86:                           textAlign: TextAlign.center,
 87:                           style: const TextStyle(
 88:                               fontSize: 24, fontWeight: FontWeight.bold),
 89:                           decoration: const InputDecoration(
 90:                               border: OutlineInputBorder()),
 91:                         ),
 92:                       ),
 93:                       const Padding(
 94:                         padding: EdgeInsets.symmetric(horizontal: 12),
 95:                         child: Text('×',
 96:                             style: TextStyle(
 97:                                 fontSize: 24, fontWeight: FontWeight.bold)),
 98:                       ),
 99:                       SizedBox(
100:                         width: 60,
101:                         child: TextField(
102:                           controller: awayCtrl,
103:                           keyboardType: TextInputType.number,
104:                           textAlign: TextAlign.center,
105:                           style: const TextStyle(
106:                               fontSize: 24, fontWeight: FontWeight.bold),
107:                           decoration: const InputDecoration(
108:                               border: OutlineInputBorder()),
109:                         ),
110:                       ),
111:                     ],
112:                   ),
113:                   if (erroDialog != null) ...[
114:                     const SizedBox(height: 8),
115:                     Text(erroDialog!,
116:                         style: const TextStyle(color: Colors.red, fontSize: 13)),
117:                   ],
118:                 ],
119:               ),
120:               actions: [
121:                 TextButton(
122:                   onPressed: () => Navigator.pop(context),
123:                   child: const Text('Cancelar'),
124:                 ),
125:                 FilledButton(
126:                   style: FilledButton.styleFrom(
127:                       backgroundColor: const Color(0xFF1A6B3C)),
128:                   onPressed: () async {
129:                     final home = int.tryParse(homeCtrl.text.trim());
130:                     final away = int.tryParse(awayCtrl.text.trim());
131:                     if (home == null || away == null) {
132:                       setDialogState(() {
133:                         erroDialog = 'Informe valores numéricos válidos.';
134:                       });
135:                       return;
136:                     }
137:                     await _salvarResultado(match, home, away);
138:                     if (context.mounted) Navigator.pop(context);
139:                   },
140:                   child: const Text('Salvar'),
141:                 ),
142:               ],
143:             );
144:           },
145:         );
146:       },
147:     );
148:     homeCtrl.dispose();
149:     awayCtrl.dispose();
150:   }
151:   Future<void> _salvarResultado(Match match, int home, int away) async {
152:     if (_cupId == null) return;
153:     final collection = match.groupId != null
154:         ? _db
155:             .collection('cups')
156:             .doc(_cupId)
157:             .collection('groups')
158:             .doc(match.groupId)
159:             .collection('matches')
160:         : _db
161:             .collection('cups')
162:             .doc(_cupId)
163:             .collection('knockout_matches');
164:     await collection.doc(match.id).update({
165:       'official_home_goals': home,
166:       'official_away_goals': away,
167:       'finished': true,
168:     });
169:     // Invalida cache para recarregar resultados atualizados
170:     MatchRepository.clearCache();
171:     await _carregar(forceRefresh: true);
172:   }
173:   @override
174:   Widget build(BuildContext context) {
175:     return Scaffold(
176:       appBar: AppBar(
177:         title: const Text('Inserir Resultados'),
178:         backgroundColor: const Color(0xFF1A6B3C),
179:         foregroundColor: Colors.white,
180:       ),
181:       body: _loading
182:           ? const Center(child: CircularProgressIndicator())
183:           : _erro != null
184:               ? Center(child: Text(_erro!))
185:               : ListView.builder(
186:                   padding: const EdgeInsets.symmetric(vertical: 8),
187:                   itemCount: _matches.length,
188:                   itemBuilder: (context, index) {
189:                     final match = _matches[index];
190:                     final home = _teams[match.homeTeamId];
191:                     final away = _teams[match.awayTeamId];
192:                     final dateStr = DateFormat('dd/MM/yyyy · HH:mm')
193:                         .format(match.matchTime);
194:                     return Card(
195:                       margin: const EdgeInsets.symmetric(
196:                           horizontal: 12, vertical: 6),
197:                       child: ListTile(
198:                         title: Text(
199:                           '${home?.name ?? match.homeTeamId} × '
200:                           '${away?.name ?? match.awayTeamId}',
201:                           style: const TextStyle(fontWeight: FontWeight.bold),
202:                         ),
203:                         subtitle: Text(dateStr),
204:                         trailing: match.finished
205:                             ? Text(
206:                                 '${match.officialHomeGoals} × '
207:                                 '${match.officialAwayGoals}',
208:                                 style: const TextStyle(
209:                                     fontWeight: FontWeight.bold,
210:                                     color: Color(0xFF1A6B3C)),
211:                               )
212:                             : const Text('Pendente',
213:                                 style: TextStyle(color: Colors.grey)),
214:                         onTap: () => _abrirEdicao(match),
215:                       ),
216:                     );
217:                   },
218:                 ),
219:     );
220:   }
221: }
