 81:   Future<void> deleteAccount() async {
 82:     final user = FirebaseAuth.instance.currentUser;
 83: 
 84:     if (user == null) {
 85:       throw Exception('Usuário não autenticado');
 86:     }
 87: 
 88:     final uid = user.uid;
 89: 
 90:     // 🔥 deletar dados do Firestore (ajuste conforme sua estrutura)
 91:     final firestore = FirebaseFirestore.instance;
 92: 
 93:     await firestore.collection('users').doc(uid).delete();
 94: 
 95:     // ⚠️ deletar outros dados vinculados se existirem
 96:     // ex: apostas, grupos, etc
 97: 
 98:     // 🔴 deletar usuário do Auth (por último)
 99:     await user.delete();
