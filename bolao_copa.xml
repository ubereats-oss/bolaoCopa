 65:   Future<UserCredential> signInWithApple() async {
 66:     final appleCredential = await SignInWithApple.getAppleIDCredential(
 67:       scopes: [
 68:         AppleIDAuthorizationScopes.email,
 69:         AppleIDAuthorizationScopes.fullName,
 70:       ],
 71:     );
 72: 
 73:     final oauthCredential = OAuthProvider("apple.com").credential(
 74:       idToken: appleCredential.identityToken,
 75:       accessToken: appleCredential.authorizationCode,
 76:     );
 77: 
 78:     return await _auth.signInWithCredential(oauthCredential);
 79:   }
