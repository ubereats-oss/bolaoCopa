362:                           height: 18,
363:                           child: CircularProgressIndicator(
364:                               strokeWidth: 2, color: Colors.white),
365:                         )
366:                       : const Icon(Icons.save_outlined),
367:                   label: const Text('Salvar todos os palpites',
368:                       style: TextStyle(fontSize: 15)),
369:                 ),
370:               ),
371:             ),
372:           ),
373:       ],
374:     );
375:   }
376: }
