 69:       setState(() {
 70:         _match = match;
 71:         _homeTeam = teams[match.homeTeamId];
 72:         _awayTeam = teams[match.awayTeamId];
 73:         _homeController.text =
 74:             prediction != null ? prediction.homeGoals.toString() : '';
 75:         _awayController.text =
 76:             prediction != null ? prediction.awayGoals.toString() : '';
 77:         _loading = false;
