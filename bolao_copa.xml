<file path="lib/features/matches/bracket_engine.dart">
  1: import '../../core/constants/bracket_data.dart';
  2: import '../../data/models/group_standing.dart';
  3: import '../../data/models/match.dart';
  4: import '../../data/models/knockout_prediction.dart';
  5: import 'package:flutter/foundation.dart';
  6: 
  7: /// Resultado resolvido de um confronto do mata-mata
  8: class ResolvedMatch {
  9:   final BracketMatchDef def;
 10:   final String? homeTeamId;
 11:   final String? awayTeamId;
 12:   final bool canPredict;
 13:   // Labels legíveis do slot, ex: '1º A', '2º B', 'Melhor 3º (A/B/C/D/F)'
 14:   final String homeSlotLabel;
 15:   final String awaySlotLabel;
 16: 
 17:   const ResolvedMatch({
 18:     required this.def,
 19:     this.homeTeamId,
 20:     this.awayTeamId,
 21:     required this.canPredict,
 22:     required this.homeSlotLabel,
 23:     required this.awaySlotLabel,
 24:   });
 25: }
 26: 
 27: class BracketEngine {
 28:   final List<Match> groupMatches;
 29:   // null = sem palpite (jogo ignorado no cálculo de classificação)
 30:   final Map<String, List<int>?> groupPredictions;
 31:   final Map<String, KnockoutPrediction> knockoutPredictions;
 32:   final Map<String, List<String>> groupTeams;
 33: 
 34:   BracketEngine({
 35:     required this.groupMatches,
 36:     required this.groupPredictions,
 37:     required this.knockoutPredictions,
 38:     required this.groupTeams,
 39:   });
 40: 
 41:   // ─── Monta groupTeams de forma robusta ────────────────────────────────────
 42:   Map<String, List<String>> _effectiveGroupTeams() {
 43:     if (groupTeams.isNotEmpty) {
 44:       return groupTeams;
 45:     }
 46:     final Map<String, List<String>> result = {};
 47:     for (final m in groupMatches) {
 48:       final gid = m.groupId;
 49:       if (gid == null || gid.isEmpty) continue;
 50:       result.putIfAbsent(gid, () => []);
 51:       if (!result[gid]!.contains(m.homeTeamId)) result[gid]!.add(m.homeTeamId);
 52:       if (!result[gid]!.contains(m.awayTeamId)) result[gid]!.add(m.awayTeamId);
 53:     }
 54:     return result;
 55:   }
 56: 
 57:   // ─── Cálculo das tabelas de grupo ─────────────────────────────────────────
 58: 
 59:   Map<String, GroupStanding> computeStandings() {
 60:     final effective = _effectiveGroupTeams();
 61:     debugPrint('=== BracketEngine ===');
 62:     debugPrint('groupMatches.length: ${groupMatches.length}');
 63:     debugPrint('groupPredictions.length: ${groupPredictions.length}');
 64:     debugPrint('groupTeams.length: ${groupTeams.length}');
 65:     debugPrint('effectiveGroupTeams.length: ${effective.length}');
 66:     debugPrint('effectiveGroupTeams keys: ${effective.keys.toList()}');
 67:     if (groupMatches.isNotEmpty) {
 68:       final m = groupMatches.first;
 69:       debugPrint(
 70:           'primeiro jogo: id=${m.id} groupId=${m.groupId} home=${m.homeTeamId} away=${m.awayTeamId}');
 71:       debugPrint('palpite primeiro jogo: ${groupPredictions[m.id]}');
 72:     }
 73: 
 74:     final Map<String, Map<String, TeamStanding>> raw = {};
 75:     for (final entry in effective.entries) {
 76:       raw[entry.key] = {
 77:         for (final t in entry.value) t: TeamStanding(teamId: t)
 78:       };
 79:     }
 80: 
 81:     for (final match in groupMatches) {
 82:       final gid = match.groupId;
 83:       if (gid == null || gid.isEmpty) continue;
 84: 
 85:       final palpite = groupPredictions[match.id];
 86:       if (palpite == null) continue; // sem palpite: ignora no cálculo
 87: 
 88:       final hGoals = palpite[0];
 89:       final aGoals = palpite[1];
 90: 
 91:       final home = raw[gid]?[match.homeTeamId];
 92:       final away = raw[gid]?[match.awayTeamId];
 93:       if (home == null || away == null) continue;
 94: 
 95:       home.goalsFor += hGoals;
 96:       home.goalsAgainst += aGoals;
 97:       away.goalsFor += aGoals;
 98:       away.goalsAgainst += hGoals;
 99: 
100:       if (hGoals > aGoals) {
101:         home.points += 3;
102:       } else if (hGoals == aGoals) {
103:         home.points += 1;
104:         away.points += 1;
105:       } else {
106:         away.points += 3;
107:       }
108:     }
109: 
110:     final result = <String, GroupStanding>{};
111:     for (final entry in raw.entries) {
112:       final sorted = entry.value.values.toList()
113:         ..sort((a, b) {
114:           final pts = b.points.compareTo(a.points);
115:           if (pts != 0) return pts;
116:           final diff = b.goalDiff.compareTo(a.goalDiff);
117:           if (diff != 0) return diff;
118:           final gf = b.goalsFor.compareTo(a.goalsFor);
119:           if (gf != 0) return gf;
120:           return a.teamId.compareTo(b.teamId);
121:         });
122:       result[entry.key] = GroupStanding(groupId: entry.key, standings: sorted);
123:     }
124:     return result;
125:   }
126: 
127:   // ─── Melhores 3ºs colocados ────────────────────────────────────────────────
128: 
129:   List<MapEntry<String, TeamStanding>> computeBestThirds(
130:       Map<String, GroupStanding> standings) {
131:     final thirds = <MapEntry<String, TeamStanding>>[];
132:     for (final gs in standings.values) {
133:       if (gs.standings.length >= 3) {
134:         thirds.add(MapEntry(gs.groupId, gs.standings[2]));
135:       }
136:     }
137:     thirds.sort((a, b) {
138:       final pts = b.value.points.compareTo(a.value.points);
139:       if (pts != 0) return pts;
140:       final diff = b.value.goalDiff.compareTo(a.value.goalDiff);
141:       if (diff != 0) return diff;
142:       final gf = b.value.goalsFor.compareTo(a.value.goalsFor);
143:       if (gf != 0) return gf;
144:       return a.key.compareTo(b.key);
145:     });
146:     return thirds.take(8).toList();
147:   }
148: 
149:   // ─── Resolução de slots ────────────────────────────────────────────────────
150: 
151:   String? resolveSlot(
152:     String code,
153:     Map<String, GroupStanding> standings,
154:     List<MapEntry<String, TeamStanding>> bestThirds,
155:     Map<String, String> winners,
156:     Set<String> usedThirds,
157:   ) {
158:     if (code.startsWith('W') || code.startsWith('L')) {
159:       final isWinner = code.startsWith('W');
160:       final matchId = code.substring(1);
161:       return isWinner ? winners['W$matchId'] : winners['L$matchId'];
162:     }
163:     if (code.startsWith('1') || code.startsWith('2')) {
164:       final pos = int.parse(code[0]) - 1;
165:       final groupId = code.substring(1);
166:       final gs = standings[groupId];
167:       if (gs == null || gs.standings.length <= pos) return null;
168:       return gs.standings[pos].teamId;
169:     }
170:     if (code.startsWith('3')) {
171:       final candidates = code.substring(1).split('');
172:       for (final entry in bestThirds) {
173:         if (candidates.contains(entry.key) && !usedThirds.contains(entry.key)) {
174:           usedThirds.add(entry.key);
175:           return entry.value.teamId;
176:         }
177:       }
178:       return null;
179:     }
180:     return null;
181:   }
182: 
183:   // ─── Label legível do slot ─────────────────────────────────────────────────
184: 
185:   String _slotLabel(String code) {
186:     if (code.startsWith('W')) return 'Vencedor ${code.substring(1)}';
187:     if (code.startsWith('L')) return 'Perdedor ${code.substring(1)}';
188:     if (code.startsWith('1')) return '1º ${code.substring(1)}';
189:     if (code.startsWith('2')) return '2º ${code.substring(1)}';
190:     if (code.startsWith('3')) {
191:       final grupos = code.substring(1).split('').join('/');
192:       return 'Melhor 3º ($grupos)';
193:     }
194:     return code;
195:   }
196: 
197:   // ─── Resolução completa do chaveamento ─────────────────────────────────────
198: 
199:   List<ResolvedMatch> resolveAll() {
200:     final standings = computeStandings();
201:     final bestThirds = computeBestThirds(standings);
202:     final Map<String, String> resolved = {};
203:     final Set<String> usedThirds = {};
204:     final phaseOrder = ['r32', 'r16', 'qf', 'sf', 'final', '3rd'];
205:     final result = <ResolvedMatch>[];
206:     final phasePredicted = <String, bool>{};
207:     phasePredicted['group'] = true;
208: 
209:     for (final phase in phaseOrder) {
210:       final matches = BracketData.matchesForPhase(phase);
211:       final prevPhase = _previousPhase(phase);
212:       final prevDone = phasePredicted[prevPhase] ?? false;
213:       bool allThisPhasePredicted = true;
214: 
215:       for (final def in matches) {
216:         final homeId = resolveSlot(
217:             def.home.code, standings, bestThirds, resolved, usedThirds);
218:         final awayId = resolveSlot(
219:             def.away.code, standings, bestThirds, resolved, usedThirds);
220: 
221:         final canPredict = prevDone && homeId != null && awayId != null;
222: 
223:         result.add(ResolvedMatch(
224:           def: def,
225:           homeTeamId: homeId,
226:           awayTeamId: awayId,
227:           canPredict: canPredict,
228:           homeSlotLabel: _slotLabel(def.home.code),
229:           awaySlotLabel: _slotLabel(def.away.code),
230:         ));
231: 
232:         final pred = knockoutPredictions[def.id];
233:         if (pred != null && homeId != null && awayId != null) {
234:           String winner;
235:           String loser;
236:           if (pred.homeGoals > pred.awayGoals) {
237:             winner = homeId;
238:             loser = awayId;
239:           } else if (pred.awayGoals > pred.homeGoals) {
240:             winner = awayId;
241:             loser = homeId;
242:           } else {
243:             winner = homeId;
244:             loser = awayId;
245:           }
246:           resolved['W${def.id}'] = winner;
247:           resolved['L${def.id}'] = loser;
248:         } else {
249:           allThisPhasePredicted = false;
250:         }
251:       }
252: 
253:       phasePredicted[phase] = allThisPhasePredicted;
254:     }
255: 
256:     return result;
257:   }
258: 
259:   String _previousPhase(String phase) {
260:     switch (phase) {
261:       case 'r32':
262:         return 'group';
263:       case 'r16':
264:         return 'r32';
265:       case 'qf':
266:         return 'r16';
267:       case 'sf':
268:         return 'qf';
269:       case 'final':
270:         return 'sf';
271:       case '3rd':
272:         return 'sf';
273:       default:
274:         return 'group';
275:     }
276:   }
277: }
