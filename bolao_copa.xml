 62:                 mainAxisSize: MainAxisSize.min,
 63:                 children: [
 64:                   TextField(
 65:                     controller: textCtrl,
 66:                     decoration: const InputDecoration(
 67:                       labelText: 'Pergunta',
 68:                       border: OutlineInputBorder(),
 69:                     ),
 70:                     maxLines: 2,
 71:                   ),
 72:                   const SizedBox(height: 16),
 73:                   const Align(
 74:                     alignment: Alignment.centerLeft,
 75:                     child: Text('Tipo de resposta:',
 76:                         style: TextStyle(fontWeight: FontWeight.bold)),
 77:                   ),
 78:                   RadioGroup<ExtraQuestionType>(
 79:                     groupValue: tipo,
 80:                     onChanged: (v) {
 81:                       if (v != null) setDialogState(() => tipo = v);
 82:                     },
 83:                     child: const Column(
 84:                       children: [
 85:                         RadioListTile<ExtraQuestionType>(
 86:                           title: Text('Seleção (time)'),
 87:                           value: ExtraQuestionType.team,
 88:                         ),
 89:                         RadioListTile<ExtraQuestionType>(
 90:                           title: Text('Jogador'),
 91:                           value: ExtraQuestionType.player,
 92:                         ),
 93:                       ],
 94:                     ),
 95:                   ),
 96:                 ],
 97:               ),
 98:               actions: [
 99:                 TextButton(
100:                   onPressed: () => Navigator.pop(context),
101:                   child: const Text('Cancelar'),
102:                 ),
103:                 FilledButton(
104:                   style: FilledButton.styleFrom(
105:                       backgroundColor: const Color(0xFF1A6B3C)),
106:                   onPressed: () async {
107:                     if (textCtrl.text.trim().isEmpty) return;
108:                     await _salvar(
109:                       id: question?.id,
110:                       text: textCtrl.text.trim(),
111:                       type: tipo,
112:                       order: question?.order ?? _questions.length,
113:                     );
114:                     if (context.mounted) Navigator.pop(context);
115:                   },
116:                   child: const Text('Salvar'),
