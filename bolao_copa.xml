<file path="firestore.rules">
 1: rules_version = '2';
 2: service cloud.firestore {
 3:   match /databases/{database}/documents {
 4: 
 5:     // ── Funções auxiliares ────────────────────────────────────────────────
 6:     function isAuth() {
 7:       return request.auth != null;
 8:     }
 9:     function isMember(groupId) {
10:       return isAuth() &&
11:         exists(/databases/$(database)/documents/bolao_groups/$(groupId)/members/$(request.auth.uid));
12:     }
13:     function isGroupAdmin(groupId) {
14:       return isAuth() &&
15:         get(/databases/$(database)/documents/bolao_groups/$(groupId)/members/$(request.auth.uid)).data.role == 'admin';
16:     }
17: 
18:     // ── Usuários ──────────────────────────────────────────────────────────
19:     match /users/{userId} {
20:       allow read: if isAuth();
21:       allow write: if isAuth() && request.auth.uid == userId;
22: 
23:       match /knockout_predictions/{slotId} {
24:         allow read: if isAuth();
25:         allow write: if isAuth() && request.auth.uid == userId;
26:       }
27:     }
28: 
29:     // ── Copa e subcoleções: leitura para autenticados ─────────────────────
30:     match /cups/{cupId} {
31:       allow read: if isAuth();
32:       match /{document=**} {
33:         allow read: if isAuth();
34:       }
35:     }
36: 
37:     match /{path=**}/matches/{matchId} {
38:       allow read: if isAuth();
39:     }
40:     match /{path=**}/teams/{teamId} {
41:       allow read: if isAuth();
42:     }
43:     match /{path=**}/players/{playerId} {
44:       allow read: if isAuth();
45:     }
46:     match /{path=**}/extra_questions/{questionId} {
47:       allow read: if isAuth();
48:     }
49: 
50:     // ── Grupos do bolão ───────────────────────────────────────────────────
51:     match /bolao_groups/{groupId} {
52:       allow get: if isAuth();
53:       allow list: if isAuth();
54:       // Criação: qualquer autenticado
55:       allow create: if isAuth();
56:       // Atualização e deleção: apenas admin do grupo
57:       allow update, delete: if isGroupAdmin(groupId);
58: 
59:       // Membros
60:       match /members/{userId} {
61:   allow read: if isMember(groupId) || (isAuth() && request.auth.uid == userId);
62:   allow create, update: if isAuth() && request.auth.uid == userId;
63:         // Admin pode remover membros
64:         allow delete: if isGroupAdmin(groupId) || request.auth.uid == userId;
65: 
66:         // Palpites de jogo — isolados por grupo
67:         match /predictions/{matchId} {
68:           allow read: if isMember(groupId);
69:           allow write: if isAuth() && request.auth.uid == userId;
70:         }
71: 
72:         // Palpites extras — isolados por grupo
73:         match /extra_predictions/{questionId} {
74:           allow read: if isMember(groupId);
75:           allow write: if isAuth() && request.auth.uid == userId;
76:         }
77:       }
78:     }
79:   }
80: }
</file>

