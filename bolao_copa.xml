  4: // O app resolve qual time ocupa cada slot em função dos palpites do usuário.
  5: 
  6: class BracketSlot {
  7:   /// Ex: '1A' = 1º do grupo A | '2B' = 2º do grupo B | '3ABCDF' = melhor 3º entre grupos A,B,C,D,F
  8:   final String code;
  9:   const BracketSlot(this.code);
 10: 
 11:   bool get isThird => code.startsWith('3');
 12: 
 13:   /// Grupos candidatos para slots de 3º colocado (ex: '3ABCDF' → ['A','B','C','D','F'])
 14:   List<String> get thirdGroups => isThird ? code.substring(1).split('') : [];
 15: }
