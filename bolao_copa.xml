 20: 
 21: class _GroupsScreenState extends State<GroupsScreen> {
 22:   final _repo = GroupRepository();
 23:   final _authService = AuthService();
 24: 
 25:   List<BolaoGroup> _groups = [];
 26:   bool _loading = true;
 27:   String? _erro;
 28: 
 29:   @override
 30:   void initState() {
 31:     super.initState();
 32:     _carregar();
 33:   }
 34: 
 35:   Future<void> _carregar() async {
 36:     setState(() {
 37:       _loading = true;
 38:       _erro = null;
 39:     });
 40:     try {
 41:       final uid = FirebaseAuth.instance.currentUser?.uid;
 42:       if (uid == null) return;
 43:       final groups = await _repo.fetchUserGroups(uid);
 44:       if (mounted) setState(() => _groups = groups);
 45:     } catch (_) {
 46:       if (mounted) setState(() => _erro = 'Erro ao carregar grupos.');
 47:     } finally {
 48:       if (mounted) setState(() => _loading = false);
 49:     }
 50:   }
 51: 
 52:   Future<void> _sair() async {
 53:     await _authService.signOut();
 54:     if (mounted) {
 55:       Navigator.of(context).pushAndRemoveUntil(
 56:         MaterialPageRoute(builder: (_) => const LoginScreen()),
 57:         (route) => false,
 58:       );
 59:     }
 60:   }
 61: 
 62:   void _abrirCriarGrupo() async {
 63:     final criado = await Navigator.push<BolaoGroup>(
 64:       context,
 65:       MaterialPageRoute(builder: (_) => const CreateGroupScreen()),
 66:     );
 67:     if (criado != null) {
 68:       setState(() => _groups.insert(0, criado));
 69:     }
 70:   }
 71: 
 72:   void _abrirEntrarGrupo() async {
 73:     final entrou = await showModalBottomSheet<BolaoGroup>(
 74:       context: context,
 75:       isScrollControlled: true,
 76:       backgroundColor: Colors.white,
 77:       shape: const RoundedRectangleBorder(
 78:         borderRadius: BorderRadius.vertical(top: Radius.circular(20)),
 79:       ),
 80:       builder: (_) => const JoinGroupSheet(),
 81:     );
 82:     if (entrou != null) {
 83:       setState(() => _groups.add(entrou));
 84:     }
 85:   }
 86: 
 87:   void _abrirGrupo(BolaoGroup group) {
 88:     Navigator.push(
 89:       context,
 90:       MaterialPageRoute(
 91:         builder: (_) => GroupHomeScreen(group: group),
 92:       ),
 93:     );
 94:   }
 95: 
 96:   Future<void> _confirmarSair(BolaoGroup group) async {
 97:     final uid = FirebaseAuth.instance.currentUser?.uid ?? '';
 98:     final isAdmin = group.adminUid == uid;
 99:     final msg = isAdmin
100:         ? 'Você é o admin. Ao sair, o grupo será apagado permanentemente.'
101:         : 'Deseja sair do grupo "${group.name}"?';
102: 
103:     final confirm = await showDialog<bool>(
104:       context: context,
105:       builder: (_) => AlertDialog(
106:         title: Text(isAdmin ? 'Apagar grupo?' : 'Sair do grupo?'),
107:         content: Text(msg),
108:         actions: [
109:           TextButton(
110:             onPressed: () => Navigator.pop(context, false),
111:             child: const Text('Cancelar'),
112:           ),
113:           FilledButton(
114:             style: FilledButton.styleFrom(backgroundColor: Colors.red),
115:             onPressed: () => Navigator.pop(context, true),
116:             child: Text(isAdmin ? 'Apagar' : 'Sair'),
117:           ),
118:         ],
119:       ),
120:     );
121: 
122:     if (confirm != true || !mounted) return;
123: 
124:     try {
125:       if (isAdmin) {
126:         await _repo.deleteGroup(group.id);
127:       } else {
128:         await _repo.leaveGroup(group.id, uid);
129:       }
130:       setState(() => _groups.removeWhere((g) => g.id == group.id));
131:     } catch (_) {
132:       if (mounted) {
133:         ScaffoldMessenger.of(context).showSnackBar(
134:           const SnackBar(content: Text('Erro ao sair do grupo.')),
135:         );
136:       }
137:     }
138:   }
139: 
140:   @override
141:   Widget build(BuildContext context) {
142:     return Scaffold(
143:       appBar: AppBar(
144:         title: const Text('Bolão Copa do Mundo'),
145:         backgroundColor: const Color(0xFF1A6B3C),
146:         foregroundColor: Colors.white,
147:         actions: [
148:           IconButton(
149:             icon: const Icon(Icons.info_outline),
150:             tooltip: 'Sobre',
151:             onPressed: () => mostrarSobre(context),
152:           ),
153:           IconButton(
154:             icon: const Icon(Icons.logout),
155:             tooltip: 'Sair',
156:             onPressed: _sair,
157:           ),
158:         ],
159:       ),
160:       body: _loading
161:           ? const Center(child: CircularProgressIndicator())
162:           : _erro != null
163:               ? Center(
164:                   child: Column(
165:                     mainAxisSize: MainAxisSize.min,
166:                     children: [
167:                       Text(_erro!, style: const TextStyle(color: Colors.red)),
168:                       const SizedBox(height: 12),
169:                       FilledButton(
170:                         onPressed: _carregar,
171:                         child: const Text('Tentar novamente'),
172:                       ),
173:                     ],
174:                   ),
175:                 )
176:               : _groups.isEmpty
177:                   ? _EmptyState(
178:                       onCriar: _abrirCriarGrupo,
179:                       onEntrar: _abrirEntrarGrupo,
180:                     )
181:                   : RefreshIndicator(
182:                       onRefresh: _carregar,
183:                       child: ListView(
184:                         padding: const EdgeInsets.fromLTRB(16, 16, 16, 100),
185:                         children: [
186:                           const Text(
187:                             'SEUS BOLÕES',
188:                             style: TextStyle(
189:                               fontSize: 12,
190:                               fontWeight: FontWeight.bold,
191:                               color: Colors.grey,
192:                               letterSpacing: 1.2,
193:                             ),
194:                           ),
195:                           const SizedBox(height: 12),
196:                           ..._groups.map(
197:                             (g) => Padding(
198:                               padding: const EdgeInsets.only(bottom: 12),
199:                               child: GroupCardBolao(
200:                                 group: g,
201:                                 onTap: () => _abrirGrupo(g),
202:                                 onLongPress: () => _confirmarSair(g),
203:                               ),
204:                             ),
205:                           ),
206:                         ],
207:                       ),
208:                     ),
209:       floatingActionButton: _groups.isEmpty
210:           ? null
211:           : Column(
212:               mainAxisSize: MainAxisSize.min,
213:               children: [
