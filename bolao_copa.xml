 15: }
 16: 
 17: class RankingScreen extends StatefulWidget {
 18:   final String groupId;
 19: 
 20:   const RankingScreen({super.key, required this.groupId});
 21: 
 22:   @override
 23:   State<RankingScreen> createState() => _RankingScreenState();
 24: }
 25: 
 26: class _RankingScreenState extends State<RankingScreen> {
 27:   final _groupRepo = GroupRepository();
 28:   final _authService = AuthService();
 29: 
 30:   List<_RankingEntry> _entries = [];
 31:   bool _loading = true;
 32:   String? _erro;
 33:   String? _currentUid;
 34: 
 35:   @override
 36:   void initState() {
 37:     super.initState();
 38:     _currentUid = FirebaseAuth.instance.currentUser?.uid;
 39:     _carregar();
 40:   }
 41: 
 42:   Future<void> _carregar() async {
 43:     setState(() {
 44:       _loading = true;
 45:       _erro = null;
 46:     });
 47:     try {
 48:       final members = await _groupRepo.fetchMembers(widget.groupId);
 49: 
 50:       // Busca nome de cada membro sem expor email
 51:       final entries = await Future.wait(
 52:         members.map((m) async {
 53:           final user = await _authService.fetchAppUser(m.userId);
 54:           return _RankingEntry(member: m, user: user);
 55:         }),
 56:       );
 57: 
 58:       if (mounted) {
 59:         setState(() {
 60:           _entries = entries.toList()
 61:             ..sort((a, b) => b.member.points.compareTo(a.member.points));
 62:           _loading = false;
 63:         });
 64:       }
 65:     } catch (_) {
 66:       if (mounted) {
 67:         setState(() {
 68:           _erro = 'Erro ao carregar ranking.';
 69:           _loading = false;
 70:         });
 71:       }
 72:     }
 73:   }
 74: 
 75:   @override
 76:   Widget build(BuildContext context) {
 77:     return Scaffold(
 78:       appBar: AppBar(
 79:         title: const Text('Ranking'),
 80:         backgroundColor: const Color(0xFF1A6B3C),
 81:         foregroundColor: Colors.white,
 82:       ),
 83:       body: _loading
 84:           ? const Center(child: CircularProgressIndicator())
 85:           : _erro != null
 86:               ? Center(
 87:                   child: Column(
 88:                     mainAxisSize: MainAxisSize.min,
 89:                     children: [
 90:                       Text(_erro!,
 91:                           style: const TextStyle(color: Colors.red)),
 92:                       const SizedBox(height: 12),
 93:                       FilledButton(
 94:                         onPressed: _carregar,
 95:                         child: const Text('Tentar novamente'),
 96:                       ),
 97:                     ],
 98:                   ),
 99:                 )
100:               : _entries.isEmpty
101:                   ? const Center(
102:                       child: Text('Nenhum participante ainda.'))
103:                   : RefreshIndicator(
104:                       onRefresh: _carregar,
105:                       child: ListView.builder(
106:                         padding: const EdgeInsets.symmetric(vertical: 8),
107:                         itemCount: _entries.length,
108:                         itemBuilder: (context, index) {
109:                           final entry = _entries[index];
110:                           final posicao = index + 1;
111:                           final isMe =
112:                               entry.member.userId == _currentUid;
113: 
114:                           return Container(
115:                             margin: const EdgeInsets.symmetric(
116:                                 horizontal: 12, vertical: 4),
117:                             decoration: BoxDecoration(
118:                               color: isMe
119:                                   ? const Color(0xFF1A6B3C)
120:                                       .withValues(alpha: 0.08)
121:                                   : null,
122:                               borderRadius: BorderRadius.circular(12),
123:                             ),
124:                             child: ListTile(
125:                               leading: _PosicaoWidget(posicao: posicao),
126:                               title: Text(
127:                                 entry.name,
128:                                 style: TextStyle(
129:                                   fontWeight: isMe
130:                                       ? FontWeight.bold
131:                                       : FontWeight.normal,
132:                                 ),
133:                               ),
134:                               subtitle: isMe
135:                                   ? const Text('Você',
136:                                       style: TextStyle(
137:                                           color: Color(0xFF1A6B3C),
138:                                           fontSize: 12))
139:                                   : null,
140:                               trailing: Text(
141:                                 '${entry.member.points} pts',
142:                                 style: const TextStyle(
143:                                   fontWeight: FontWeight.bold,
144:                                   fontSize: 16,
145:                                 ),
146:                               ),
147:                             ),
148:                           );
149:                         },
150:                       ),
151:                     ),
152:     );
153:   }
154: }
