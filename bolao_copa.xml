  7: class GroupRepository {
  8:   final FirebaseFirestore _db = FirebaseFirestore.instance;
  9: 
 10:   CollectionReference get _groups => _db.collection('bolao_groups');
 11: 
 12:   // ── Gera código de convite único (6 chars alfanumérico) ──────────────────
 13:   String _generateCode() {
 14:     const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
 15:     final rnd = DateTime.now().millisecondsSinceEpoch;
 16:     var result = '';
 17:     var seed = rnd;
 18:     for (var i = 0; i < 6; i++) {
 19:       result += chars[seed % chars.length];
 20:       seed = (seed ~/ chars.length) + i * 7;
 21:     }
 22:     return result;
 23:   }
 24: 
 25:   // ── Criar grupo ──────────────────────────────────────────────────────────
 26:   Future<BolaoGroup> createGroup({
 27:     required String name,
 28:     required String cupId,
 29:     required String adminUid,
 30:   }) async {
 31:     final inviteCode = _generateCode();
 32:     final now = DateTime.now();
 33: 
 34:     final ref = await _groups.add({
 35:       'name': name.trim(),
 36:       'admin_uid': adminUid,
 37:       'invite_code': inviteCode,
 38:       'cup_id': cupId,
 39:       'created_at': Timestamp.fromDate(now),
 40:     });
 41: 
 42:     // Admin vira membro com role 'admin'
 43:     await ref.collection('members').doc(adminUid).set({
 44:       'role': 'admin',
 45:       'points': 0,
 46:       'joined_at': Timestamp.fromDate(now),
 47:     });
 48: 
 49:     // Registra groupId no array do usuário para lookup sem índice composto
 50:     await _db.collection('users').doc(adminUid).set({
 51:       'group_ids': FieldValue.arrayUnion([ref.id]),
 52:     }, SetOptions(merge: true));
 53: 
 54:     final doc = await ref.get();
 55:     return BolaoGroup.fromFirestore(doc.id, doc.data() as Map<String, dynamic>);
 56:   }
 57: 
 58:   // ── Entrar por código de convite ─────────────────────────────────────────
 59:   Future<BolaoGroup?> joinByCode(String code, String userId) async {
 60:     final query = await _groups
 61:         .where('invite_code', isEqualTo: code.trim().toUpperCase())
 62:         .limit(1)
 63:         .get();
 64: 
 65:     if (query.docs.isEmpty) return null;
 66: 
 67:     final doc = query.docs.first;
 68:     final groupId = doc.id;
 69: 
 70:     // Verifica se já é membro
 71:     final memberDoc =
 72:         await _groups.doc(groupId).collection('members').doc(userId).get();
 73:     if (memberDoc.exists) {
 74:       return BolaoGroup.fromFirestore(
 75:           doc.id, doc.data() as Map<String, dynamic>);
 76:     }
 77: 
 78:     final now = DateTime.now();
 79:     await _groups.doc(groupId).collection('members').doc(userId).set({
 80:       'role': 'member',
 81:       'points': 0,
 82:       'joined_at': Timestamp.fromDate(now),
 83:     });
 84: 
 85:     await _db.collection('users').doc(userId).set({
 86:       'group_ids': FieldValue.arrayUnion([groupId]),
 87:     }, SetOptions(merge: true));
 88: 
 89:     return BolaoGroup.fromFirestore(doc.id, doc.data() as Map<String, dynamic>);
 90:   }
 91: 
 92:   // ── Buscar grupos do usuário ─────────────────────────────────────────────
 93:   Future<List<BolaoGroup>> fetchUserGroups(String userId) async {
 94:     final userDoc = await _db.collection('users').doc(userId).get();
 95:     final data = userDoc.data() ?? {};
 96:     final ids = List<String>.from(data['group_ids'] ?? []);
 97:     if (ids.isEmpty) return [];
 98: 
 99:     final docs = await Future.wait(ids.map((id) => _groups.doc(id).get()));
100:     return docs
101:         .where((d) => d.exists)
102:         .map((d) =>
103:             BolaoGroup.fromFirestore(d.id, d.data() as Map<String, dynamic>))
104:         .toList();
105:   }
106: 
107:   // ── Buscar membros de um grupo ordenados por pontos ──────────────────────
108:   Future<List<BolaoMember>> fetchMembers(String groupId) async {
109:     final snap = await _groups
110:         .doc(groupId)
111:         .collection('members')
112:         .orderBy('points', descending: true)
113:         .get();
114:     return snap.docs
115:         .map((d) => BolaoMember.fromFirestore(d.id, d.data()))
116:         .toList();
117:   }
118: 
119:   // ── Palpite de jogo por grupo ────────────────────────────────────────────
120:   CollectionReference _predictions(String groupId, String userId) => _groups
121:       .doc(groupId)
122:       .collection('members')
123:       .doc(userId)
124:       .collection('predictions');
125: 
126:   Future<Prediction?> fetchPrediction(
127:       String groupId, String userId, String matchId) async {
128:     final doc = await _predictions(groupId, userId).doc(matchId).get();
129:     if (!doc.exists) return null;
130:     return Prediction.fromFirestore(matchId, doc.data() as Map<String, dynamic>);
131:   }
132: 
133:   Future<Map<String, Prediction>> fetchAllPredictions(
134:       String groupId, String userId) async {
135:     final snap = await _predictions(groupId, userId).get();
136:     return {
137:       for (final d in snap.docs)
138:         d.id: Prediction.fromFirestore(d.id, d.data() as Map<String, dynamic>)
139:     };
140:   }
141: 
142:   Future<void> savePrediction(String groupId, Prediction p) async {
143:     await _predictions(groupId, p.userId).doc(p.matchId).set(p.toFirestore());
144:   }
145: 
146:   // ── Palpite extra por grupo ──────────────────────────────────────────────
147:   CollectionReference _extraPredictions(String groupId, String userId) =>
148:       _groups
149:           .doc(groupId)
150:           .collection('members')
151:           .doc(userId)
152:           .collection('extra_predictions');
153: 
154:   Future<Map<String, ExtraPrediction>> fetchAllExtraPredictions(
155:       String groupId, String userId) async {
156:     final snap = await _extraPredictions(groupId, userId).get();
157:     return {
158:       for (final d in snap.docs)
159:         d.id: ExtraPrediction.fromFirestore(
160:             d.id, d.data() as Map<String, dynamic>)
161:     };
162:   }
163: 
164:   Future<void> saveExtraPrediction(
165:       String groupId, ExtraPrediction p) async {
166:     await _extraPredictions(groupId, p.userId)
167:         .doc(p.questionId)
168:         .set(p.toFirestore());
169:   }
170: 
171:   // ── Atualizar pontos de um membro ────────────────────────────────────────
172:   Future<void> updateMemberPoints(
173:       String groupId, String userId, int points) async {
174:     await _groups
175:         .doc(groupId)
176:         .collection('members')
177:         .doc(userId)
178:         .update({'points': points});
179:   }
180: 
181:   // ── Verificar se usuário é membro ────────────────────────────────────────
182:   Future<BolaoMember?> fetchMember(String groupId, String userId) async {
183:     final doc =
184:         await _groups.doc(groupId).collection('members').doc(userId).get();
185:     if (!doc.exists) return null;
186:     return BolaoMember.fromFirestore(doc.id, doc.data()!);
187:   }
188: 
189:   // ── Sair do grupo ────────────────────────────────────────────────────────
190:   Future<void> leaveGroup(String groupId, String userId) async {
191:     await _groups.doc(groupId).collection('members').doc(userId).delete();
192:     await _db.collection('users').doc(userId).update({
193:       'group_ids': FieldValue.arrayRemove([groupId]),
194:     });
195:   }
196: 
197:   // ── Deletar grupo (apenas admin) ─────────────────────────────────────────
198:   Future<void> deleteGroup(String groupId) async {
199:     final uid = FirebaseAuth.instance.currentUser?.uid;
200:     if (uid == null) return;
201: 
202:     // Remove groupId de todos os membros
203:     final members =
204:         await _groups.doc(groupId).collection('members').get();
205:     for (final m in members.docs) {
206:       await _db.collection('users').doc(m.id).update({
207:         'group_ids': FieldValue.arrayRemove([groupId]),
208:       });
209:     }
210:     await _groups.doc(groupId).delete();
211:   }
212: }
